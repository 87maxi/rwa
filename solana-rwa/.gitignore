# =============================================================================
# RWA Solana - Git Ignore
# Centralized ignore patterns for the entire project
# =============================================================================

# =============================================================================
# Build Artifacts
# =============================================================================
# Anchor build outputs
.target/
**/target/
.anchor/

# Rust compiled binaries
**/*.rlib
**/*.so
**/*.dll
**/*.exe

# Node modules
node_modules/
**/node_modules/

# Package lock (track in git for reproducibility)
# package-lock.json  # Uncomment if you prefer not to track
# yarn.lock  # Uncomment if you prefer not to track

# =============================================================================
# Test Ledger & State
# =============================================================================
test-ledger/
**/test-ledger/

# Surfpool: Ignore logs and temporary files, but keep state files
.surfpool/logs/
.surfpool/*.lock
# Keep state files for deployment tracking:
# .surfpool/state/deployment.*.tx-state.json

# =============================================================================
# IDE & Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.orig

# =============================================================================
# Generated Files
# =============================================================================
idl/
types/
**/*.d.ts

# =============================================================================
# Logs & Debug
# =============================================================================
*.log
deploy_output.log
**/*.log

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.local
.env.*.local
*.json.bak
*.key
*.secret

# =============================================================================
# Keys - NEVER commit keypairs
# =============================================================================
keys/
**/keys/*.json
!keys/.gitignore

# =============================================================================
# Backup Files
# =============================================================================
**/*.rs.bk
**/*.ts.bk
**/*.sh.bk

# =============================================================================
# Yarn
# =============================================================================
.yarn/
**/.yarn/

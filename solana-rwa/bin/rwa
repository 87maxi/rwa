#!/usr/bin/env bash
# =============================================================================
# RWA Solana - Unified CLI
# Single entry point for all deployment operations
# =============================================================================
set -euo pipefail

# =============================================================================
# Constants & Configuration
# =============================================================================
VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../" && pwd)"
CONFIG_FILE="$PROJECT_ROOT/rwa.config.yaml"
CONFIG_DIR="$PROJECT_ROOT/config"
PROGRAMS_DIR="$PROJECT_ROOT/programs"
RUNBOOKS_DIR="$PROJECT_ROOT/runbooks"
IDP_DIR="$PROJECT_ROOT/idl"
TYPES_DIR="$PROJECT_ROOT/types"
DEPLOY_DIR="$PROJECT_ROOT/target/deploy"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# =============================================================================
# Utility Functions
# =============================================================================
log_info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
log_success() { echo -e "${GREEN}[OK]${NC} $*"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
log_step()    { echo -e "${BOLD}${CYAN}[$*]${NC}"; }

check_dependency() {
    local cmd="$1"
    local msg="${2:-$cmd}"
    if ! command -v "$cmd" &>/dev/null; then
        log_error "$msg not found: $cmd"
        return 1
    fi
    return 0
}

check_solana_cluster() {
    local cluster="${1:-localnet}"
    local rpc_url

    case "$cluster" in
        localnet) rpc_url="http://127.0.0.1:8899" ;;
        devnet)   rpc_url="https://api.devnet.solana.com" ;;
        mainnet)  rpc_url="https://api.mainnet-beta.solana.com" ;;
        *)        log_error "Unknown cluster: $cluster"; return 1 ;;
    esac

    local health
    health=$(curl -s -X POST -H "Content-Type: application/json" \
        -d '{"jsonrpc":"2.0","id":1,"method":"getHealth"}' \
        "$rpc_url" 2>/dev/null || echo "error")

    if [[ "$health" == *"ok"* ]]; then
        log_success "Cluster $cluster is reachable"
        return 0
    else
        log_error "Cluster $cluster is not reachable at $rpc_url"
        return 1
    fi
}

# Helper to parse program ID from Anchor.toml under [programs.localnet]
_parse_anchor_toml_id() {
    local program_name="$1"
    local toml_file="$2"

    awk -v prog="$program_name" '
        /\[programs\.localnet\]/ { found=1; next }
        /\[/ { found=0 }
        found {
            split($0, a, "=")
            gsub(/^[ \t]+|[ \t]+$/, "", a[1])
            if (a[1] == prog) {
                gsub(/"/, "", a[2])
                gsub(/^[ \t]+|[ \t]+$/, "", a[2])
                print a[2]
            }
        }
    ' "$toml_file"
}

get_program_id() {
    local env="$1"
    local program="$2"
    local config_file="$CONFIG_FILE"

    # Check for .address file first (from solana program deploy)
    local addr_file="$PROJECT_ROOT/target/deploy/${program}.address"
    if [[ -f "$addr_file" ]]; then
        local id
        id=$(cat "$addr_file")
        if [[ -n "$id" ]]; then
            echo "$id"
            return 0
        fi
    fi

    # Try to extract from rwa.config.yaml first
    local id
    id=$(python3 -c "
import yaml, sys
try:
    with open(sys.argv[1]) as f:
        data = yaml.safe_load(f)
    programs = data.get('programs', {}).get(sys.argv[2], {})
    key = sys.argv[3]
    print(programs.get(key, ''))
except Exception:
    print('')
" "$config_file" "$env" "$program" 2>/dev/null || echo "")

    # Fallback: check Anchor.toml for localnet
    if [[ -z "$id" && "$env" == "localnet" ]]; then
        id=$(_parse_anchor_toml_id "$program" "$PROJECT_ROOT/Anchor.toml")
    fi

    echo "$id"
}

# =============================================================================
# Command: setup
# =============================================================================
cmd_setup() {
    log_step "SETUP"
    log_info "Checking and installing dependencies..."

    local errors=0

    # Rust & Solana
    log_info "Checking Rust..."
    if ! check_dependency rustc "Rust"; then
        log_warn "Installing Rust..."
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
        source "$HOME/.cargo/env" 2>/dev/null || true
    fi

    log_info "Checking Solana CLI..."
    if ! check_dependency solana "Solana CLI"; then
        log_warn "Installing Solana CLI..."
        sh -c "$(curl -sSfL https://release.solana.com/stable/install)"
        export PATH="$HOME/.local/share/solana/install/active_release/bin:$PATH"
    fi

    log_info "Checking Anchor CLI..."
    if ! check_dependency anchor "Anchor CLI"; then
        log_warn "Installing Anchor CLI..."
        cargo install --git https://github.com/coral-xyz/anchor anchor-cli --locked --force
    fi

    log_info "Checking Surfpool CLI..."
    if ! check_dependency surfpool "Surfpool CLI"; then
        log_warn "Surfpool CLI not found. Install from: https://docs.surfpool.run/"
        errors=$((errors + 1))
    fi

    log_info "Checking TXTX CLI..."
    if ! check_dependency txtx "TXTX CLI"; then
        log_warn "TXTX CLI not found. Install from: https://docs.txtx.sh/"
        errors=$((errors + 1))
    fi

    # Node.js & npm/yarn
    log_info "Checking Node.js..."
    if ! check_dependency node "Node.js"; then
        log_warn "Node.js not found. Install from: https://nodejs.org/"
        errors=$((errors + 1))
    else
        log_info "Node.js version: $(node --version)"
        log_info "npm version: $(npm --version)"
    fi

    # Install project dependencies
    log_info "Installing project dependencies..."
    cd "$PROJECT_ROOT"
    if [[ -f "package.json" ]]; then
        npm install --prefix "$PROJECT_ROOT" 2>/dev/null || {
            log_warn "npm install failed, trying yarn..."
            if command -v yarn &>/dev/null; then
                yarn install --cwd "$PROJECT_ROOT" 2>/dev/null || true
            else
                log_error "Neither npm nor yarn could install dependencies"
                errors=$((errors + 1))
            fi
        }
    fi

    if [[ $errors -eq 0 ]]; then
        log_success "All dependencies ready!"
    else
        log_warn "$errors dependency(ies) missing. Review output above."
    fi

    return $errors
}

# =============================================================================
# Command: build
# =============================================================================
cmd_build() {
    log_step "BUILD"
    log_info "Building Solana programs with Anchor..."

    cd "$PROJECT_ROOT"

    # Clean previous build if FORCE_BUILD is set
    if [[ "${FORCE_BUILD:-false}" == "true" ]]; then
        log_info "Clean build requested..."
        cmd_clean
    fi

    # Build with Anchor (run from project root, no --manifest-path needed)
    if command -v anchor &>/dev/null; then
        anchor build
    else
        log_error "Anchor not found. Run: rwa setup"
        return 1
    fi

    # Copy binaries to deploy directory (if different from target/deploy)
    # Note: Rust/Anchor outputs with underscores (compliance_aggregator.so)
    mkdir -p "$DEPLOY_DIR"
    for program in compliance_aggregator identity_registry solana_rwa; do
        local bin_src="$PROJECT_ROOT/target/deploy/${program}.so"
        local bin_dst="$DEPLOY_DIR/${program}.so"
        if [[ -f "$bin_src" ]]; then
            # Skip copy if source and destination are the same file
            if [[ "$(realpath "$bin_src")" == "$(realpath "$bin_dst" 2>/dev/null || echo "")" ]]; then
                log_success "Binary available: ${program}.so"
            else
                cp "$bin_src" "$bin_dst"
                log_success "Copied ${program}.so to $DEPLOY_DIR"
            fi
        fi
    done

    log_success "Build complete!"
}

# =============================================================================
# Command: test
# =============================================================================
cmd_test() {
    log_step "TEST"
    log_info "Running all test suites..."

    cd "$PROJECT_ROOT"

    # Ensure surfpool is running for localnet tests
    if ! check_solana_cluster localnet 2>/dev/null; then
        log_warn "Surfpool not running. Start with: surfpool --program-path $PROJECT_ROOT/programs"
        log_warn "Skipping tests that require localnet..."
    fi

    # Run Anchor tests
    log_info "Running Anchor program tests..."
    if command -v anchor &>/dev/null; then
        anchor test 2>&1 || {
            log_warn "Anchor tests had failures. Continuing to JS tests..."
        }
    fi

    # Run TypeScript tests
    log_info "Running TypeScript integration tests..."
    if command -v npx &>/dev/null; then
        npx ts-mocha -p "$PROJECT_ROOT/tsconfig.json" -t 1000000 "$PROJECT_ROOT/tests/**/*.ts" 2>&1 || {
            log_warn "TypeScript tests had failures."
        }
    fi

    log_success "Test run complete!"
}

# =============================================================================
# Command: deploy
# =============================================================================
cmd_deploy() {
    local target="${1:-local}"
    log_step "DEPLOY to $target"

    case "$target" in
        local|localnet|surfpool)
            _deploy_localnet
            ;;
        devnet)
            _deploy_devnet
            ;;
        mainnet|main)
            _deploy_mainnet
            ;;
        *)
            log_error "Unknown target: $target"
            log_info "Valid targets: local, devnet, mainnet"
            return 1
            ;;
    esac
}

_deploy_localnet() {
    log_step "LOCALNET DEPLOYMENT PIPELINE"
    log_info "Target: Surfpool localnet (instant deployment enabled)"

    cd "$PROJECT_ROOT"

    # Step 1: Build programs
    log_info "Step 1/8: Building programs..."
    cmd_build

    # Step 2: Start Surfpool if not running
    log_info "Step 2/8: Checking Surfpool..."
    if check_solana_cluster localnet 2>/dev/null; then
        log_success "Surfpool is already running"
    else
        log_info "Starting Surfpool..."
        surfpool --program-path "$PROJECT_ROOT/programs" --reset 2>&1 &
        local surfpool_pid=$!
        log_info "Waiting for Surfpool to start..."
        sleep 5

        # Wait for Surfpool to be ready
        local attempts=0
        while ! check_solana_cluster localnet 2>/dev/null && [[ $attempts -lt 30 ]]; do
            sleep 2
            attempts=$((attempts + 1))
            log_info "Waiting for Surfpool... (attempt $attempts/30)"
        done

        if check_solana_cluster localnet 2>/dev/null; then
            log_success "Surfpool started successfully"
        else
            log_error "Failed to start Surfpool"
            return 1
        fi
    fi

    # Step 3: Setup Surfpool environment
    log_info "Step 3/8: Setting up Surfpool environment..."
    # Surfpool auto-loads programs from --program-path when using instant_deployment
    log_info "Surfpool will auto-load programs via instant_deployment"

    # Step 4: Deploy programs via solana CLI (not anchor deploy to avoid ID mismatch)
    log_info "Step 4/8: Deploying programs..."
    _deploy_programs_solana_cli

    # Step 5: Extract and sync program IDs
    log_info "Step 5/8: Syncing program IDs..."
    _sync_program_ids

    # Step 6: Initialize programs
    log_info "Step 6/8: Initializing programs..."
    _init_programs_local

    # Step 7: Verify deployment
    log_info "Step 7/8: Verifying deployment..."
    _verify_deployment

    # Step 8: Generate IDLs and types
    log_info "Step 8/8: Generating IDLs and types..."
    cmd_idl

    log_success "Localnet deployment complete!"
    log_info "Program IDs:"
    for program in compliance_aggregator identity_registry solana_rwa; do
        local id
        id=$(get_program_id localnet "$program")
        log_info "  $program: $id"
    done
}

_deploy_programs_solana_cli() {
    cd "$PROJECT_ROOT"

    # Airdrop if needed
    solana airdrop 1 2>/dev/null || true

    # Deploy in order: compliance_aggregator, identity_registry, solana_rwa
    # Using direct solana program deploy (not anchor deploy) to avoid
    # DeclaredProgramIdMismatch errors on localnet where program IDs change
    for program in compliance_aggregator identity_registry solana_rwa; do
        log_info "Deploying $program..."
        local bin="$DEPLOY_DIR/${program}.so"
        if [[ ! -f "$bin" ]]; then
            log_warn "Binary not found: $bin. Building first..."
            anchor build --program-name "$program"
        fi

        if [[ -f "$bin" ]]; then
            # Deploy using solana CLI directly (bypasses Anchor.toml program ID check)
            local deploy_output
            deploy_output=$(solana program deploy "$bin" 2>&1) || {
                log_error "Failed to deploy $program"
                echo "$deploy_output"
                return 1
            }
            # Extract program ID from output (last 44-character base58 string)
            local deployed_id
            deployed_id=$(echo "$deploy_output" | grep -oE '[1-9A-HJ-NP-Za-km-z]{32,44}' | tail -1)
            if [[ -n "$deployed_id" ]]; then
                log_success "Deployed $program -> $deployed_id"
                # Store deployed ID for later sync
                echo "$deployed_id" > "$PROJECT_ROOT/target/deploy/${program}.address"
            else
                log_warn "Could not extract program ID from output: $deploy_output"
            fi
        else
            log_error "Binary missing for $program: $bin"
            return 1
        fi
    done
}

_sync_program_ids() {
    log_info "Syncing program IDs from deployment..."

    cd "$PROJECT_ROOT"

    local -a deployed_ids=()

    # Read from .address files (created by solana program deploy)
    for program in compliance_aggregator identity_registry solana_rwa; do
        local addr_file="$PROJECT_ROOT/target/deploy/${program}.address"
        if [[ -f "$addr_file" ]]; then
            local id
            id=$(cat "$addr_file")
            deployed_ids+=("${program}=${id}")
            log_info "  $program: $id (from .address file)"
        fi
    done

    if [[ ${#deployed_ids[@]} -eq 0 ]]; then
        log_warn "No deployed program IDs found"
        return 1
    fi

    # Update Anchor.toml with deployed IDs for localnet
    _update_anchor_toml_ids "$(IFS='|'; echo "${deployed_ids[*]}")"

    # Update YAML config with deployed IDs
    _update_yaml_config_ids "$(IFS='|'; echo "${deployed_ids[*]}")"

    # Update frontend config
    _update_frontend_config_ids "$(IFS='|'; echo "${deployed_ids[*]}")"
}

_update_anchor_toml_ids() {
    local ids_str="$1"
    local toml_file="$PROJECT_ROOT/Anchor.toml"

    if [[ ! -f "$toml_file" ]]; then
        log_warn "Anchor.toml not found, skipping update"
        return
    fi

    log_info "Updating Anchor.toml with deployed program IDs..."

    python3 -c "
import sys
import re

toml_file = sys.argv[1]
ids_str = sys.argv[2]

# Parse IDs from arguments
ids = {}
for pair in ids_str.split('|'):
    if '=' in pair:
        prog, pid = pair.split('=', 1)
        ids[prog] = pid

with open(toml_file, 'r') as f:
    lines = f.readlines()

output = []
in_programs_section = False

for line in lines:
    if '[programs.localnet]' in line:
        in_programs_section = True
        output.append(line)
        continue
    if line.startswith('[') and '[programs.localnet]' not in line:
        in_programs_section = False
    if in_programs_section and '=' in line:
        match = re.match(r'^(\s*)(\w+)(\s*=\s*)(.*)', line)
        if match:
            key = match.group(2)
            if key in ids:
                output.append(f\"{match.group(1)}{key}{match.group(3)}\\\"{ids[key]}\\\"\n\")
                continue
    output.append(line)

with open(toml_file, 'w') as f:
    f.writelines(output)
" "$toml_file" "$ids_str"

    log_success "Anchor.toml updated"
}

_update_yaml_config_ids() {
    local ids_str="$1"
    local config_file="$CONFIG_FILE"

    if [[ ! -f "$config_file" ]]; then
        log_warn "Config file not found, skipping YAML update"
        return
    fi

    log_info "Updating rwa.config.yaml with deployed program IDs..."

    python3 -c "
import yaml
import sys

config_file = sys.argv[1]
ids_str = sys.argv[2]

with open(config_file) as f:
    data = yaml.safe_load(f)

if 'programs' not in data:
    data['programs'] = {}
if 'localnet' not in data['programs']:
    data['programs']['localnet'] = {}

for pair in ids_str.split('|'):
    if '=' in pair:
        prog, pid = pair.split('=', 1)
        data['programs']['localnet'][prog] = pid

with open(config_file, 'w') as f:
    yaml.dump(data, f, default_flow_style=False, sort_keys=False)

print('  YAML config updated')
" "$config_file" "$ids_str"

    log_success "YAML config updated"
}

_update_frontend_config_ids() {
    local ids_str="$1"
    local frontend_config="$PROJECT_ROOT/../web/src/config/solana.ts"

    if [[ ! -f "$frontend_config" ]]; then
        log_warn "Frontend config not found at $frontend_config"
        return
    fi

    log_info "Updating frontend config..."

    EXPORTED_FRONTEND_CONFIG="$frontend_config" EXPORTED_IDS_STR="$ids_str" python3 << 'PYEOF'
import os

frontend_config = os.environ['EXPORTED_FRONTEND_CONFIG']
ids_str = os.environ['EXPORTED_IDS_STR']

with open(frontend_config, 'r') as f:
    lines = f.readlines()

# Map program names to config keys (camelCase)
program_to_key = {
    'compliance_aggregator': 'complianceAggregator',
    'identity_registry': 'identityRegistry',
    'solana_rwa': 'solanaRwa'
}

# Parse IDs
ids = {}
for pair in ids_str.split('|'):
    if '=' in pair:
        prog, pid = pair.split('=', 1)
        ids[prog] = pid

output = []
for line in lines:
    stripped = line.strip()
    updated = False
    for prog, key in program_to_key.items():
        target = key + ": '"
        if stripped.startswith(target) and stripped.endswith("',"):
            indent = line[:len(line) - len(line.lstrip())]
            if prog in ids:
                pid = ids[prog]
                output.append(indent + key + ': "' + pid + '",\n')
                print(f"  Updated {key} -> {pid}")
                updated = True
                break
    if not updated:
        output.append(line)

with open(frontend_config, 'w') as f:
    f.writelines(output)

print("  Frontend config updated")
PYEOF

    log_success "Frontend config updated"
}

_deploy_devnet() {
    log_step "DEVNET DEPLOYMENT PIPELINE"
    log_info "Target: Solana Devnet (browser wallet signing required)"
    log_warn "This will require SOL for deployment fees on devnet"

    # Check devnet connectivity
    check_solana_cluster devnet || {
        log_error "Cannot reach devnet"
        return 1
    }

    # Build first
    cmd_build

    # Deploy via Anchor (will prompt for browser wallet)
    log_info "Deploying to devnet with Anchor..."
    cd "$PROJECT_ROOT"
    anchor deploy --provider.cluster devnet 2>&1 || {
        log_error "Devnet deployment failed"
        return 1
    }

    # Sync IDs
    _sync_program_ids

    log_success "Devnet deployment complete!"
}

_deploy_mainnet() {
    log_step "MAINNET DEPLOYMENT PIPELINE"
    log_info "Target: Solana Mainnet (multisig signing required)"
    log_warn "MAINNET DEPLOYMENT: This is a production operation!"

    # Pre-flight checks
    log_info "Running pre-flight checks..."

    # Check for audit requirement
    if [[ ! -f "$PROJECT_ROOT/AUDIT_REPORT.md" ]]; then
        log_warn "No audit report found. Mainnet deployment should be audited."
        log_warn "Proceeding anyway (--force-mainnet bypasses this check)"
    fi

    check_solana_cluster mainnet || {
        log_error "Cannot reach mainnet"
        return 1
    }

    cmd_build

    log_info "Deploying to mainnet..."
    cd "$PROJECT_ROOT"
    anchor deploy --provider.cluster mainnet 2>&1 || {
        log_error "Mainnet deployment failed"
        return 1
    }

    _sync_program_ids

    log_success "Mainnet deployment complete!"
}

# =============================================================================
# Command: init
# =============================================================================
cmd_init() {
    local env="${1:-local}"
    log_step "INIT programs on $env"

    case "$env" in
        local|localnet) _init_programs_local ;;
        devnet) _init_programs_devnet ;;
        mainnet) _init_programs_mainnet ;;
        *)
            log_error "Unknown environment: $env"
            log_info "Valid environments: local, devnet, mainnet"
            return 1
            ;;
    esac
}

_init_programs_local() {
    log_info "Initializing programs on localnet..."

    cd "$PROJECT_ROOT"

    # Get program IDs from .address files or Anchor.toml
    local compliance_id identity_id rwa_id
    compliance_id=$(get_program_id localnet compliance_aggregator)
    identity_id=$(get_program_id localnet identity_registry)
    rwa_id=$(get_program_id localnet solana_rwa)

    if [[ -z "$compliance_id" || -z "$identity_id" || -z "$rwa_id" ]]; then
        log_warn "Program IDs not available. Skipping initialization."
        log_info "Run 'rwa deploy local' first to deploy programs."
        return 1
    fi

    log_info "Compliance Aggregator: $compliance_id"
    log_info "Identity Registry: $identity_id"
    log_info "Solana RWA: $rwa_id"

    # Run TXTX initialization if available
    if command -v txtx &>/dev/null && [[ -d "$RUNBOOKS_DIR" ]]; then
        log_info "Running TXTX initialization..."
        cd "$RUNBOOKS_DIR"

        # Token initialization
        if [[ -d "token-initialization" && -f "token-initialization/main.tx" ]]; then
            log_info "Running token initialization..."
            txtx run token-initialization --input network=localnet 2>&1 || {
                log_warn "Token initialization failed. You may need to run it manually."
            }
        fi

        # Identity initialization
        if [[ -d "identity-initialization" && -f "identity-initialization/main.tx" ]]; then
            log_info "Running identity initialization..."
            txtx run identity-initialization --input network=localnet 2>&1 || {
                log_warn "Identity initialization failed."
            }
        fi

        # Compliance initialization
        if [[ -d "compliance-initialization" && -f "compliance-initialization/main.tx" ]]; then
            log_info "Running compliance initialization..."
            txtx run compliance-initialization --input network=localnet 2>&1 || {
                log_warn "Compliance initialization failed."
            }
        fi
    else
        log_info "TXTX not available or runbooks missing. Skipping TXTX init."
        log_info "You can initialize programs manually with:"
        log_info "  solana program write-buffer <program.so>"
        log_info "  solana program deploy --program-name <name> <program_keypair.json>"
    fi

    log_success "Initialization complete!"
}

_init_programs_devnet() {
    log_info "Initializing programs on devnet..."
    log_warn "This will require devnet SOL"

    cd "$PROJECT_ROOT"

    if command -v txtx &>/dev/null && [[ -d "$RUNBOOKS_DIR" ]]; then
        cd "$RUNBOOKS_DIR"
        txtx run token-initialization --input network=devnet 2>&1 || {
            log_warn "Token initialization on devnet failed."
        }
        txtx run identity-initialization --input network=devnet 2>&1 || {
            log_warn "Identity initialization on devnet failed."
        }
        txtx run compliance-initialization --input network=devnet 2>&1 || {
            log_warn "Compliance initialization on devnet failed."
        }
    else
        log_error "TXTX not available"
        return 1
    fi
}

_init_programs_mainnet() {
    log_info "Initializing programs on mainnet..."
    log_warn "This is a production operation! Ensure multisig is configured."

    cd "$PROJECT_ROOT"

    if command -v txtx &>/dev/null && [[ -d "$RUNBOOKS_DIR" ]]; then
        cd "$RUNBOOKS_DIR"
        txtx run token-initialization --input network=mainnet 2>&1 || {
            log_warn "Token initialization on mainnet failed."
        }
        txtx run identity-initialization --input network=mainnet 2>&1 || {
            log_warn "Identity initialization on mainnet failed."
        }
        txtx run compliance-initialization --input network=mainnet 2>&1 || {
            log_warn "Compliance initialization on mainnet failed."
        }
    else
        log_error "TXTX not available"
        return 1
    fi
}

# =============================================================================
# Command: upgrade
# =============================================================================
cmd_upgrade() {
    local program="${1:-}"
    local env="${2:-local}"

    if [[ -z "$program" ]]; then
        log_error "Program name required"
        log_info "Usage: rwa upgrade <program> [local|devnet|mainnet]"
        log_info "Available programs: compliance_aggregator, identity_registry, solana_rwa"
        return 1
    fi

    log_step "UPGRADE $program on $env"

    cd "$PROJECT_ROOT"

    # Use underscores for program names (matching file system)
    local program_underscored="${program//-/_}"
    local bin="$DEPLOY_DIR/${program_underscored}.so"
    if [[ ! -f "$bin" ]]; then
        log_error "Binary not found: $bin"
        log_info "Run: rwa build"
        return 1
    fi

    # Get current program ID
    local current_id
    current_id=$(get_program_id "$env" "$program_underscored")
    if [[ -z "$current_id" ]]; then
        log_error "Program ID not found for $program on $env"
        return 1
    fi

    log_info "Current $program ID: $current_id"
    log_info "Upgrading to: $bin"

    # Deploy using solana program deploy
    local deploy_output
    deploy_output=$(solana program deploy --program-id "$current_id" "$bin" 2>&1) || {
        log_error "Upgrade failed"
        echo "$deploy_output"
        return 1
    }

    log_success "Upgrade complete!"
}

# =============================================================================
# Command: status
# =============================================================================
cmd_status() {
    local env="${1:-local}"
    log_step "STATUS on $env"

    cd "$PROJECT_ROOT"

    local rpc_url
    case "$env" in
        local|localnet) rpc_url="http://127.0.0.1:8899" ;;
        devnet)         rpc_url="https://api.devnet.solana.com" ;;
        mainnet)        rpc_url="https://api.mainnet-beta.solana.com" ;;
        *)              log_error "Unknown environment: $env"; return 1 ;;
    esac

    echo ""
    echo -e "${BOLD}Program Status on $env:${NC}"
    echo "============================================"

    for program in compliance_aggregator identity_registry solana_rwa; do
        local id
        id=$(get_program_id "$env" "$program")

        if [[ -n "$id" ]]; then
            # Query program account info
            local account_info
            account_info=$(curl -s -X POST -H "Content-Type: application/json" \
                -d "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getAccountInfo\",\"params\":[\"$id\",{\"encoding\":\"jsonParsed\"}]}" \
                "$rpc_url" 2>/dev/null || echo "{}")

            local owner
            owner=$(echo "$account_info" | python3 -c "
import json, sys
data = json.load(sys.stdin)
result = data.get('result', {}).get('value')
if result:
    print(result.get('owner', 'unknown'))
else:
    print('not found')
" 2>/dev/null || echo "unknown")

            local lamports
            lamports=$(echo "$account_info" | python3 -c "
import json, sys
data = json.load(sys.stdin)
result = data.get('result', {}).get('value')
if result:
    print(result.get('lamports', 0))
else:
    print(0)
" 2>/dev/null || echo "0")

            if [[ "$owner" == "Program" ]]; then
                echo -e "  ${GREEN}$program${NC}"
                echo "    ID:       $id"
                echo "    Owner:    $owner"
                echo "    Lamports: $lamports"
            else
                echo -e "  ${YELLOW}$program${NC} (not deployed on-chain)"
                echo "    ID: $id"
            fi
        else
            echo -e "  ${RED}$program${NC} (ID not configured)"
        fi
        echo ""
    done
}

# =============================================================================
# Command: idl
# =============================================================================
cmd_idl() {
    log_step "IDL GENERATION"

    cd "$PROJECT_ROOT"

    mkdir -p "$IDP_DIR" "$TYPES_DIR"

    # Generate IDLs from Anchor
    for program in compliance_aggregator identity_registry solana_rwa; do
        log_info "Generating IDL for $program..."

        local idl_out="$IDP_DIR/${program}.json"
        local types_out="$TYPES_DIR/${program}.ts"

        if command -v anchor &>/dev/null; then
            anchor idl build --program-name "$program" -o "$idl_out" 2>&1 || {
                log_warn "IDL build failed for $program. Trying extract..."

                # Try to extract IDL from deployed program
                anchor idl extract --program-name "$program" -o "$idl_out" 2>&1 || {
                    log_warn "IDL extract failed for $program. IDL file may already exist."
                }
            }

            # Generate TypeScript types from IDL
            if [[ -f "$idl_out" ]]; then
                log_info "Generating TypeScript types for $program..."
                anchor idl ts "$idl_out" -o "$types_out" 2>&1 || {
                    log_warn "TypeScript type generation failed for $program"
                }
            fi
        else
            log_error "Anchor not found. Cannot generate IDLs."
            return 1
        fi

        if [[ -f "$idl_out" ]]; then
            log_success "IDL: $idl_out"
        fi
        if [[ -f "$types_out" ]]; then
            log_success "Types: $types_out"
        fi
    done

    log_success "IDL generation complete!"
}

# =============================================================================
# Command: clean
# =============================================================================
cmd_clean() {
    log_step "CLEAN"
    log_info "Cleaning build artifacts..."

    cd "$PROJECT_ROOT"

    # Clean Anchor targets
    if [[ -d "target" ]]; then
        log_info "Removing target/..."
        rm -rf target
    fi

    # Clean Anchor cache
    if [[ -d ".anchor" ]]; then
        log_info "Removing .anchor/..."
        rm -rf .anchor
    fi

    # Clean test ledger
    if [[ -d "test-ledger" ]]; then
        log_info "Removing test-ledger/..."
        rm -rf test-ledger
    fi

    # Clean Surfpool state
    if [[ -d ".surfpool" ]]; then
        log_info "Removing .surfpool/..."
        rm -rf .surfpool
    fi

    # Clean deployed addresses
    for program in compliance_aggregator identity_registry solana_rwa; do
        local addr_file="$PROJECT_ROOT/target/deploy/${program}.address"
        if [[ -f "$addr_file" ]]; then
            rm -f "$addr_file"
            log_info "Removed ${program}.address"
        fi
    done

    log_success "Clean complete!"
}

# =============================================================================
# Command: validate
# =============================================================================
cmd_validate() {
    log_step "VALIDATE Configuration"

    cd "$PROJECT_ROOT"

    local errors=0

    # Check rwa.config.yaml
    if [[ -f "$CONFIG_FILE" ]]; then
        log_success "rwa.config.yaml found"
    else
        log_error "rwa.config.yaml missing"
        errors=$((errors + 1))
    fi

    # Check program directories
    for program in compliance_aggregator identity_registry solana_rwa; do
        if [[ -d "$PROGRAMS_DIR/$program" ]]; then
            if [[ -f "$PROGRAMS_DIR/$program/Cargo.toml" ]]; then
                log_success "Program $program: Cargo.toml found"
            else
                log_error "Program $program: Cargo.toml missing"
                errors=$((errors + 1))
            fi
            if [[ -f "$PROGRAMS_DIR/$program/src/lib.rs" ]]; then
                log_success "Program $program: src/lib.rs found"
            else
                log_error "Program $program: src/lib.rs missing"
                errors=$((errors + 1))
            fi
        else
            log_error "Program directory missing: $PROGRAMS_DIR/$program"
            errors=$((errors + 1))
        fi
    done

    # Check Anchor.toml
    if [[ -f "Anchor.toml" ]]; then
        log_success "Anchor.toml found"

        # Validate program IDs in Anchor.toml using proper TOML parser
        for program in solana_rwa identity_registry compliance_aggregator; do
            local id
            id=$(_parse_anchor_toml_id "$program" "Anchor.toml")
            if [[ -n "$id" && ${#id} -ge 32 ]]; then
                log_success "  $program: $id"
            else
                log_error "  $program: Invalid or missing ID"
                errors=$((errors + 1))
            fi
        done
    else
        log_error "Anchor.toml missing"
        errors=$((errors + 1))
    fi

    # Check config overlays
    for env in localnet devnet mainnet; do
        if [[ -f "$CONFIG_DIR/${env}.yaml" ]]; then
            log_success "Config overlay: ${env}.yaml found"
        else
            log_warn "Config overlay missing: ${env}.yaml"
        fi
    done

    # Check runbooks
    if [[ -d "$RUNBOOKS_DIR" ]]; then
        log_success "Runbooks directory found"
        local runbook_count
        runbook_count=$(find "$RUNBOOKS_DIR" -name "*.tx" | wc -l)
        log_info "Found $runbook_count TXTX runbook files"
    else
        log_warn "No runbooks directory"
    fi

    if [[ $errors -eq 0 ]]; then
        log_success "Configuration valid!"
    else
        log_error "$errors validation error(s) found"
    fi

    return $errors
}

# =============================================================================
# Command: verify-deployment
# =============================================================================
_verify_deployment() {
    log_info "Verifying deployed programs..."

    cd "$PROJECT_ROOT"

    for program in compliance_aggregator identity_registry solana_rwa; do
        local id
        id=$(get_program_id localnet "$program")

        if [[ -n "$id" ]]; then
            local account_info
            account_info=$(curl -s -X POST -H "Content-Type: application/json" \
                -d "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getAccountInfo\",\"params\":[\"$id\",{\"encoding\":\"base64\"}]}" \
                "http://127.0.0.1:8899" 2>/dev/null || echo "{}")

            local owner
            owner=$(echo "$account_info" | python3 -c "
import json, sys
data = json.load(sys.stdin)
result = data.get('result', {}).get('value')
if result:
    print(result.get('owner', ''))
else:
    print('')
" 2>/dev/null || echo "")

            if [[ "$owner" == "Program" ]]; then
                log_success "$program is deployed and active ($id)"
            else
                log_warn "$program may not be properly deployed (owner: $owner)"
            fi
        else
            log_warn "$program: No program ID found"
        fi
    done
}

# =============================================================================
# Command: version
# =============================================================================
cmd_version() {
    echo "RWA Solana CLI v$VERSION"
    echo ""
    echo "Tools:"
    echo "  Anchor:    $(anchor --version 2>/dev/null || echo 'not installed')"
    echo "  Solana:    $(solana --version 2>/dev/null || echo 'not installed')"
    echo "  Surfpool:  $(surfpool --version 2>/dev/null || echo 'not installed')"
    echo "  TXTX:      $(txtx --version 2>/dev/null || echo 'not installed')"
    echo "  Node:      $(node --version 2>/dev/null || echo 'not installed')"
}

# =============================================================================
# Command: explain
# =============================================================================
cmd_explain() {
    echo -e "${BOLD}RWA Solana CLI - Unified Deployment Tool${NC}"
    echo ""
    echo "USAGE:"
    echo "    rwa <command> [arguments]"
    echo ""
    echo "COMMANDS:"
    echo "    setup                    Install and check all dependencies"
    echo "    build                    Compile all Solana programs"
    echo "    test                     Run all test suites"
    echo "    deploy <env>             Deploy to environment (local|devnet|mainnet)"
    echo "    init [env]               Initialize programs after deployment (default: local)"
    echo "    upgrade <program>        Upgrade a specific program"
    echo "    status [env]             Check program status on network (default: local)"
    echo "    idl                      Generate IDLs and TypeScript types"
    echo "    clean                    Remove build artifacts"
    echo "    validate                 Validate project configuration"
    echo "    version                  Show CLI and tool versions"
    echo "    explain                  Show this help message"
    echo ""
    echo "EXAMPLES:"
    echo "    rwa setup                        # Install dependencies"
    echo "    rwa build                        # Build all programs"
    echo "    rwa deploy local                 # Deploy to Surfpool localnet"
    echo "    rwa deploy devnet                # Deploy to Solana devnet"
    echo "    rwa init local                   # Initialize programs on localnet"
    echo "    rwa upgrade solana-rwa local     # Upgrade solana-rwa program"
    echo "    rwa status local                 # Check deployment status"
    echo "    rwa idl                          # Generate IDLs"
    echo "    rwa validate                     # Validate configuration"
    echo ""
    echo "ENVIRONMENT VARIABLES:"
    echo "    FORCE_BUILD=true                 # Force clean build"
    echo "    RWA_CONFIG=/path/to/config.yaml  # Custom config path"
    echo ""
    echo "CONFIGURATION:"
    echo "    Main config:  rwa.config.yaml"
    echo "    Overlays:     config/*.yaml"
    echo "    Runbooks:     runbooks/"
    echo ""
    echo "SUPPORT:"
    echo "    Surfpool:  https://docs.surfpool.run/"
    echo "    TXTX:      https://docs.txtx.sh/"
    echo "    Anchor:    https://www.anchor-lang.com/"
}

# =============================================================================
# Main Dispatcher
# =============================================================================
main() {
    local cmd="${1:-explain}"
    shift 2>/dev/null || true

    case "$cmd" in
        setup|init)     "cmd_$cmd" "$@" ;;
        build)          cmd_build ;;
        test)           cmd_test ;;
        deploy)         cmd_deploy "$@" ;;
        upgrade)        cmd_upgrade "$@" ;;
        status)         cmd_status "$@" ;;
        idl)            cmd_idl ;;
        clean)          cmd_clean ;;
        validate)       cmd_validate ;;
        version|-v|--version) cmd_version ;;
        explain|-h|--help|help) cmd_explain ;;
        *)
            log_error "Unknown command: $cmd"
            cmd_explain
            return 1
            ;;
    esac
}

# Run main with all arguments
main "$@"
